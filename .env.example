# Copy to .env and adjust. Used by docker compose (see docker-compose.yml).

# MongoDB (root user; ReaperC2 uses MONGO_AUTH_SOURCE=admin in compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=reaperc2_dev_root

# Published ports on the host
MONGO_HOST_PORT=27017
BEACON_HOST_PORT=8080
ADMIN_HOST_PORT=8443

# App database name (collections live here)
MONGO_DATABASE=api_db

# First operator created when operators collection is empty
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=changeme

# Shown in admin panel Scythe example (your machine -> published beacon port)
BEACON_PUBLIC_BASE_URL=http://127.0.0.1:8080
# Default Scythe --proxy host:port when a beacon has a parent (pivot); override per beacon via UI pivot_proxy
# BEACON_PIVOT_PROXY=172.17.0.4:2222
