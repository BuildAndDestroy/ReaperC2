# Copy to .env and adjust. Used by docker compose (see docker-compose.yml).

# MongoDB (root user; ReaperC2 uses MONGO_AUTH_SOURCE=admin in compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=reaperc2_dev_root

# Published ports on the host
MONGO_HOST_PORT=27017
BEACON_HOST_PORT=8080
ADMIN_HOST_PORT=8443

# App database name (collections live here)
MONGO_DATABASE=api_db

# First operator created when operators collection is empty
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=changeme

# Optional: branch/tag for Scythe when Docker build clones third_party/Scythe (no submodule on disk). Default: main
# SCYTHE_GIT_REF=main

# Shown in admin panel Scythe example (your machine -> published beacon port)
BEACON_PUBLIC_BASE_URL=http://127.0.0.1:8080
# Default Scythe --proxy host:port when a beacon has a parent (pivot); override per beacon via UI pivot_proxy
# BEACON_PIVOT_PROXY=172.17.0.4:2222

# Operator AI (/ai) — list multiple models; UI offers Auto + each enabled model
# REAPER_AI_ENABLED=1
# REAPER_AI_DEFAULT_MODEL=auto
# REAPER_AI_DEFAULT_PROVIDER=openai
# REAPER_AI_MAX_TOKENS=2048
#
# Optional unified catalog (overrides per-provider *_MODELS lists):
# REAPER_AI_MODELS=openai:gpt-5.5,anthropic:claude-opus-4-7,foundry:gpt-5.5,bedrock:anthropic.claude-opus-4-7,ollama:llama3.2
#
# OpenAI (legacy REAPER_AI_API_KEY / REAPER_AI_API_URL / REAPER_AI_MODEL still work)
# REAPER_AI_OPENAI_API_KEY=sk-...
# REAPER_AI_OPENAI_API_URL=https://api.openai.com/v1
# With OPENAI_API_KEY set, REAPER_AI_OPENAI_DISCOVER=1 (default) lists models from GET /v1/models.
# Curated latest (gpt-5.5, gpt-4.1, …) are always merged into the dropdown when discovery is on.
# REAPER_AI_OPENAI_MODELS=gpt-5.5,gpt-4.1
#
# Anthropic
# REAPER_AI_ANTHROPIC_API_KEY=sk-ant-...
# REAPER_AI_ANTHROPIC_API_URL=https://api.anthropic.com/v1
# With ANTHROPIC_API_KEY set, REAPER_AI_ANTHROPIC_DISCOVER=1 (default) lists models from GET /v1/models.
# REAPER_AI_ANTHROPIC_MODELS=claude-opus-4-7,claude-sonnet-4-6
#
# Azure AI Foundry (OpenAI-compatible v1 — also accepts AZURE_OPENAI_* env names)
# REAPER_AI_FOUNDRY_API_KEY=
# REAPER_AI_FOUNDRY_API_URL=https://myresource.openai.azure.com
# REAPER_AI_FOUNDRY_DISCOVER=1
# REAPER_AI_FOUNDRY_MODELS=gpt-5.5,gpt-4.1
# REAPER_AI_FOUNDRY_USE_API_KEY_HEADER=0
# Legacy Azure env names (optional): AZURE_OPENAI_API_KEY, AZURE_OPENAI_ENDPOINT
#
# Ollama — run on the host (ollama serve / app), then enable Operator AI:
# REAPER_AI_OLLAMA_ENABLED=1
# REAPER_AI_OLLAMA_DISCOVER=1
# With DISCOVER=1 (default when Ollama is enabled), the Operator AI dropdown lists models from `ollama list` automatically.
# Optional REAPER_AI_OLLAMA_MODELS adds extra names (merged with discovered tags).
# Mac/Windows Docker Desktop (Ollama on host localhost:11434):
# REAPER_AI_OLLAMA_API_URL=http://host.docker.internal:11434/v1
# Linux + COMPOSE_PROFILES=ollama-host (socat on docker bridge, not LAN):
# COMPOSE_PROFILES=ollama-host
# REAPER_AI_OLLAMA_API_URL=http://172.17.0.1:11434/v1
#
# AWS Bedrock — pick one auth method:
#   (A) Bedrock API key from the console (bearer token; recommended for dev)
# REAPER_AI_BEDROCK_API_KEY=
#   (B) IAM access key + secret (+ optional SESSION_TOKEN for STS/temp creds)
# REAPER_AI_BEDROCK_ACCESS_KEY_ID=
# REAPER_AI_BEDROCK_SECRET_ACCESS_KEY=
# REAPER_AI_BEDROCK_SESSION_TOKEN=
#   (C) EKS/IRSA — no keys; set REAPER_AI_BEDROCK_USE_IAM=1
# REAPER_AI_BEDROCK_ENABLED=1
# REAPER_AI_BEDROCK_REGION=us-east-1
# REAPER_AI_BEDROCK_USE_IAM=1
# Claude 4.x requires inference profile IDs for Converse (us-east-1 → us.* prefix):
# REAPER_AI_BEDROCK_INFERENCE_PREFIX=us
# REAPER_AI_BEDROCK_MODELS=us.anthropic.claude-opus-4-7,us.anthropic.claude-sonnet-4-6,amazon.nova-lite-v1:0
# REAPER_AI_BEDROCK_MODEL=us.anthropic.claude-opus-4-7
